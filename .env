# ============================
# 学习强企 · 企业微信机器人打卡系统
# 配置项说明：
# 1. 填写 WECOM_WEBHOOK_URL（必填）—— 企业微信群机器人 Webhook 地址
# 2. DEEPSEEK_API_KEY 已预填，如需更换可修改
# 3. BASE_URL 改为你服务器的公网地址（如 http://你的公网IP:8080）
# ============================

# 企业微信群机器人 Webhook（必填：在企业微信群里添加机器人后获取的地址）
WECOM_WEBHOOK_URL=

# DeepSeek API 密钥（预填）
DEEPSEEK_API_KEY=sk-f76d44f5c99c4d8fbcd010bfe9741496

# 服务器公网地址（外部可访问，用于生成答题链接，末尾不要加 /）
BASE_URL=http://localhost:8080

# 服务器监听配置（一般无需修改）
HOST=0.0.0.0
PORT=8080

# 管理员 @提及（选填：在统计消息中@管理员，填写企业微信账号）
ADMIN_MENTION=

# 定时推送时间（24小时制）
PUSH_TIME=09:00
STATS_TIME=18:00
REMINDER_TIME=16:00
REMINDER_DAY=5

# 企业微信群名称（桌面推送用，填写群聊名称）
WECOM_GROUP_NAME=智善经理级及以上（十五五规划每日考试）
